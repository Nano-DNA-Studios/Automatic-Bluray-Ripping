@page "/configuretranscode"
@rendermode InteractiveServer
@inject MediaScannerManager Manager
@inject SubtitleQueue SubQueue

<PageTitle>Transcode Configuration</PageTitle>

@if (SubQueue.IsVisible)
{
	<div style="position: fixed; top: 0; left: 0; width: 100vw; height: 100vh; background-color: rgba(0,0,0,0.8); z-index: 9999; display: flex; justify-content: center; align-items: center; color: white;">
		<div style="background-color: #333; padding: 30px; border-radius: 10px; width: 80%; max-height: 80%; overflow-y: auto; position: relative;">

			<button style="position: absolute; top: 10px; right: 10px; padding: 5px 10px;" @onclick="SubQueue.ClosePreview">X</button>

			@if (SubQueue.ActiveStream != null)
			{
				<h2>Subtitle Preview - @SubQueue.ActiveStream.Language</h2>
				<hr style="border-color: #555;" />

				<p>Showing full track preview for Stream ID: @SubQueue.ActiveStream.ID</p>
				<p>Format: @SubQueue.ActiveStream.Format</p>
				<p>Name: @SubQueue.ActiveStream.Name</p>

				@if (SubQueue.ActiveStream.Images.Length == 0)
				{
					<div style="display: flex; flex-direction: column; align-items: center; justify-content: center; padding: 40px;">
						<div class="spinner"></div>
						<p style="margin-top: 15px; font-weight: 500; color: #555;">Loading Images...</p>
					</div>
				}
				else
				{
					@foreach (string image in SubQueue.ActiveStream.Images)
					{
						<div>
							<img src="@image" alt="Video Thumbnail" style="width: 1000px; height: auto; border-radius: 4px;" />
						</div>
					}
				}
			}
		</div>
	</div>
}


<h3>Configure Transcode</h3>

@if (Manager.IsScanning)
{
	<div style="display: flex; flex-direction: column; align-items: center; justify-content: center; padding: 40px;">
		<div class="spinner"></div>
		<p style="margin-top: 15px; font-weight: 500; color: #555;">Scanning...</p>
	</div>
}
else
{
	<div style="display: flex; flex-direction: column; justify-content: flex-start;gap:10px;">

		<div style="font-size:x-large">
			<button @onclick="@LoadHanbrakePresets">
				Refresh Handbrake Preset
			</button>

			<button @onclick="@LoadMKVBackups">
				Load MKV Backups
			</button>
		</div>

		@foreach (MKVBackup backup in Manager.Backups)
		{
			<div style="padding: 10px; border-radius: 10px; background-color:lightblue;">
				<details>
					<summary>
						<div>

							<div style="display: flex; flex-direction: row; justify-content: flex-start; gap:10px;">
								<h3>@backup.Name</h3>
								<h3>(@backup.GetTotalVideos() Videos)</h3>
							</div>

							<div style="display: flex; flex-direction: row; justify-content: flex-start; align-items:center; gap:10px;">
								<input type="checkbox"
									   class="form-check-input"
									   id="delete-on-complete"
									   @bind="@backup.RemoveOnCompletion"
									   style="width: 30px; height:30px; margin:0px" />

								<h4 style="margin:0px;">Delete on Completion</h4>
							</div>

							<div style="display: flex; flex-direction: row; justify-content: flex-start; gap:10px; align-items:center;" @onclick:stopPropagation="true">
								<h4 style="margin:0px">Choose Transcode Preset:</h4>
								<select id="formatSelect" style="flex-grow: 1; margin:0px" class="custom-form-control" @bind="backup.TranscodePreset">
									<option value="">-- Select a Format --</option>
									@foreach (string preset in Manager.Presets)
									{
										<option value="@preset">@Path.GetFileNameWithoutExtension(preset)</option>
									}
								</select>
							</div>
						</div>

						<button style="width: 100%; padding: 10px; margin-top: 10px;" @onclick="() => Manager.AddToTranscodeQueue(backup)">
							Transcode
						</button>
					</summary>

					@foreach (var category in backup.VideoCategories.Values)
					{
						<VideoCategory Category="@category" />
					}
				</details>
			</div>
		}
	</div>
}

@code {

	protected override void OnInitialized()
	{
		Manager.OnProgressUpdated += UpdateProgress;
		SubQueue.OnChange += UpdateProgress;
	}

	private void LoadHanbrakePresets()
	{
		Manager.LoadHandbrakePresets();
	}

	private void LoadMKVBackups()
	{
		Manager.LoadMKVBackups();
	}

	private void UpdateProgress()
	{
		InvokeAsync(StateHasChanged);
	}

	public void Dispose()
	{
		Console.WriteLine("Dispose MKV");
		Manager.OnProgressUpdated -= UpdateProgress;
		SubQueue.OnChange -= UpdateProgress;
	}
}