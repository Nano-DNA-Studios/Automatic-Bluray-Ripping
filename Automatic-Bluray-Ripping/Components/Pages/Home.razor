@page "/"
@rendermode InteractiveServer
@using MediaInfo;
@using MediaInfo.Model;
@inject NavigationManager Nav
@inject TranscodeQueueService QueueService

<PageTitle>Transcode Configuration</PageTitle>

<div style="
    display: grid;
    grid-template-columns: 1fr 1fr 1fr ;
    gap: 15px;
width:fit-content;
">
	<div style="text-align: center; padding:10px; background-color: gray; border-radius: 10px;">
		<img style ="width:200px; height:200px;" src="hdd.svg" />
		<h2>Backup Bluray</h2>
	</div>

	<div style="text-align: center; padding:10px; background-color: gray; border-radius: 10px;">
		<img style="width:200px; height:200px;" src="file-video.svg" />
		<h2>Make MKV</h2>
	</div>

	<div style="text-align: center; padding:10px; background-color: gray; border-radius: 10px;">
		<img style="width:200px; height:200px;" src="convert.svg" />
		<h2>Configure Transcode</h2>
	</div>

</div>

<div>
	<div>
		<h3 for="formatSelect">Choose Transcode Preset:</h3>
		<select id="formatSelect" class="form-control" @bind="TranscodePreset">
			<option value="">-- Select a Format --</option>
			@foreach (string preset in Presets)
			{
				<option value="@preset">@Path.GetFileNameWithoutExtension(preset)</option>
			}
		</select>
	</div>

	<button style="width: 100%; padding: 10px; margin-top: 10px" @onclick="@GoToTranscode">
		Transcode
	</button>
</div>

@foreach (var category in VideoCategories.Values)
{
	<VideoCategory Category="@category" />
}

@code {

	string exeDir = Path.GetDirectoryName(Environment.ProcessPath);

	private const string BDMV = "BDMV";
	private const string STREAM = "STREAM";

	private string directoryPath = "Blurays";

	private string mkvDir = @"D:\NanoDNA Studios\Development\Automatic-Bluray-Ripping\Automatic-Bluray-Ripping\bin\Debug\net8.0\Blurays\Fairy_Tail_Extract";
	private string mkvFile = @"D:\NanoDNA Studios\Development\Automatic-Bluray-Ripping\Automatic-Bluray-Ripping\bin\Debug\net8.0\Blurays\Fairy_Tail_Extract\FairyTail Part15 Disc 2_t02.mkv";

	private string[] MKVFiles = [];
	private string[] Presets = [];

	private string TranscodePreset = "";

	private VideoMetadata[] Metadata;

	private Dictionary<string, VideoCategoryMetadata> VideoCategories = new Dictionary<string, VideoCategoryMetadata>();

	private bool UseVideo = true;
	private bool UseAudio = true;
	private bool UseSubtitles = true;
	private bool UseChapters = true;

	protected override async Task OnInitializedAsync()
	{
		Console.WriteLine("Starting Program...");

		if (VideoCategories.Count > 0) return;

		VideoCategories = new Dictionary<string, VideoCategoryMetadata>();
		Metadata = GetVideoMetadata(mkvDir);
		Presets = GetHandbrakePresets();

		ComputeCategories();

		directoryPath = Path.Combine(exeDir, directoryPath);

		if (!Directory.Exists(directoryPath))
		{
			Console.WriteLine("Directory Doesn't Exist");
			return;
		}

		string[] dirs = Directory.EnumerateDirectories(directoryPath).ToArray();

		foreach (string dir in dirs)
		{
			if (!IsBlurayBackup(dir))
			{
				//Just read the Files / find all video files? (Search for .mkv only?)
				Console.WriteLine("The Directory is not a Bluray");
				continue;
			}

			// foreach (string file in GetAllBlurayVideoFiles(GetBlurayStreamDir(dir)))
			// {
			// 	DisplayMediaInfo(file);
			// }

			// foreach (string file in GetAllMKVFiles(mkvDir))
			// {
			// 	DisplayMediaInfo(file);
			// }
			//DisplayMediaInfo(mkvFile);
		}
	}

	private string[] GetHandbrakePresets()
	{
		string fullPath = Path.GetDirectoryName(Environment.ProcessPath);
		string presetDir = "HandbrakePresets";

		if (!Directory.Exists(fullPath))
			return [];

		fullPath = Path.Combine(fullPath, presetDir);

		if (!Directory.Exists(fullPath))
			return [];

		return Directory.GetFiles(fullPath);
	}

	private void RecomputeCategories(ChangeEventArgs e)
	{
		ComputeCategories();
	}

	private void ComputeCategories()
	{
		Console.WriteLine("Computing");
		Dictionary<string, VideoCategoryMetadata> videoCategories = new Dictionary<string, VideoCategoryMetadata>();

		int index = 1;

		foreach (VideoMetadata metadata in Metadata)
		{
			//Add buttons that control the bools
			string signature = metadata.GetSignature(UseVideo, UseAudio, UseSubtitles, UseChapters);

			if (!videoCategories.ContainsKey(signature))
			{
				videoCategories.Add(signature, new VideoCategoryMetadata($"Category {index}"));
				index++;
			}

			videoCategories[signature].AddMetadata(metadata);
		}

		VideoCategories = videoCategories;

	}

	private bool IsBlurayBackup(string basePath)
	{
		string fullPath = basePath;
		string[] dirs;

		if (!Directory.Exists(fullPath))
			return false;

		dirs = Directory.GetDirectories(fullPath);

		if (!dirs.Contains(Path.Combine(fullPath, BDMV)))
		{
			//Console.WriteLine("No BDMV Folder");
			return false;
		}

		fullPath = Path.Combine(fullPath, BDMV);

		if (!Directory.Exists(fullPath))
			return false;

		dirs = Directory.GetDirectories(fullPath);

		if (!dirs.Contains(Path.Combine(fullPath, STREAM)))
		{
			//Console.WriteLine("No STREAM Folder");
			return false;
		}

		return true;
	}

	private string GetBlurayStreamDir(string basePath)
	{
		return Path.Combine(basePath, BDMV, STREAM);
	}

	private string[] GetAllBlurayVideoFiles(string streamPath)
	{
		const string extension = "*.m2ts";

		return Directory.GetFiles(streamPath, extension);
	}

	private string[] GetAllMKVFiles(string mkvDir)
	{
		const string extension = "*.mkv";

		return Directory.GetFiles(mkvDir, extension);
	}

	private VideoMetadata[] GetVideoMetadata(string path)
	{
		List<VideoMetadata> metadata = new List<VideoMetadata>();
		string[] MKVFiles = GetAllMKVFiles(mkvDir);


		foreach (string mkvFile in MKVFiles)
		{
			metadata.Add(new VideoMetadata(mkvFile));
		}

		return metadata.ToArray();
	}

	private void GoToTranscode()
	{
		List<TranscodeJob> transcodeJobs = new();

		foreach (string key in VideoCategories.Keys)
		{
			VideoCategories[key].CleanCategory();

			foreach (VideoMetadata metadata in VideoCategories[key].Metadata)
			{
				if (!metadata.IsSelected)
					continue;

				QueueService.EnqueueJob(new TranscodeJob()
				{
					Name = metadata.Name,
					InputFilePath = metadata.FilePath,
					OutputFilePath = Path.Combine(DefaultSettings.DefaultTranscodeDirectory, Path.GetFileName(metadata.Name) + ".mkv"),
					Args = metadata.GetTranscodeArgs(),
					ThumbnailBase64 = metadata.ThumbnailBase64,
					TranscodePreset = TranscodePreset
				});
			}
		}

		Nav.NavigateTo("/transcode");
	}

	private void DisplayMediaInfo(string filePath)
	{
		Console.WriteLine($"Analyzing File : {filePath}");

		try
		{

			MediaInfoWrapper mediaFile = new MediaInfoWrapper(filePath);

			// 1. General Container Metadata
			Console.WriteLine($"Size: {mediaFile.Size} bytes");
			Console.WriteLine($"Duration: {TimeSpan.FromMilliseconds(mediaFile.Duration):hh\\:mm\\:ss}");
			Console.WriteLine($"Total Bitrate: {mediaFile.VideoRate} bps");

			// 2. Video Track Details
			foreach (var video in mediaFile.VideoStreams)
			{
				Console.WriteLine($"[Video Track #{video.Id}]");
				Console.WriteLine($"  Codec: {video.CodecName} / {video.Format}");
				Console.WriteLine($"  Profile: {video.CodecProfile}");
				Console.WriteLine($"  Resolution: {video.Width}x{video.Height}");
				Console.WriteLine($"  Framerate: {video.FrameRate} FPS");
				Console.WriteLine($"  Bitrate: {video.Bitrate} bps");
			}

			// 3. Audio Track Details
			foreach (var audio in mediaFile.AudioStreams)
			{
				Console.WriteLine($"[Audio Track #{audio.Id} ({audio.Name})]");
				Console.WriteLine($"  Format: {audio.Format} ({audio.CodecName}, {audio.CodecFriendly})");
				Console.WriteLine($"  Channels: {audio.Channel} ({audio.StreamPosition})");
				Console.WriteLine($"  Language: {audio.Language} ({audio.LanguageIetf})");
				Console.WriteLine($"  Bitrate: {audio.Bitrate} bps");
			}

			// 4. Subtitle Track Details
			foreach (var subtitle in mediaFile.Subtitles)
			{
				Console.WriteLine($"[Subtitle Track #{subtitle.Id} ({subtitle.Name})]");
				Console.WriteLine($"  Format: {subtitle.Format}");
				Console.WriteLine($"  Language: {subtitle.Language} ({subtitle.LanguageIetf})");
				Console.WriteLine($"  Default: {subtitle.Default}");
			}
		}
		catch (Exception ex)
		{
			Console.WriteLine($"Error reading metadata for {Path.GetFileName(filePath)}: {ex.Message}");
		}

		Console.WriteLine("Done Analyzing... \n\n");
	}

}
