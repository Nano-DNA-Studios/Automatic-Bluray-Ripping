@page "/transcode"
@using System.Diagnostics
@rendermode InteractiveServer
@inject TranscodeStateService StateService

<PageTitle>Transcode</PageTitle>

<h3>Transcode</h3>

<progress value="@CurrentProgressPercent" max="100" style="width: 100%; height: 25px;"></progress>

@foreach (var category in StateService.SelectedCategories)
{
	<details style="background-color: darkgray; padding: 10px; border-radius: 10px; margin: 10px">
		<summary>
			@category.Name
			(@category.Metadata.Count Videos)
		</summary>

		<div>
			@foreach (var metadata in category.Metadata)
			{
				<VideoFile Metadata="@metadata" />
			}
		</div>
	</details>
}

@code {

	private List<VideoCategoryMetadata> VideoCategories;

	private string TranscodePreset = "";

	private double CurrentProgressPercent = 0;

	protected override async Task OnInitializedAsync()
	{
		VideoCategories = StateService.SelectedCategories;
		TranscodePreset = StateService.HandbrakePreset;

		int index = 1;

		foreach (VideoCategoryMetadata category in VideoCategories)
		{
			foreach (VideoMetadata metadata in category.Metadata)
			{
				string arguments = $"--preset-import-file \"{TranscodePreset}\" -Z \"{Path.GetFileNameWithoutExtension(TranscodePreset)}\" -i \"{metadata.FilePath}\" -o \"{Path.Combine(Path.GetDirectoryName(metadata.FilePath), $"output_{index}.mkv")}\"{metadata.GetTranscodeArgs()}";

				index++;

				Console.WriteLine(arguments);

				ProcessStartInfo startInfo = new ProcessStartInfo
				{
					FileName = @"C:\Program Files\HandBrake\HandBrakeCLI.exe",
					Arguments = arguments,
					RedirectStandardOutput = true,
					RedirectStandardError = true,
					UseShellExecute = false,
					CreateNoWindow = true
				};

				using (Process process = new Process { StartInfo = startInfo })
				{
					// 1. Attach the event handlers to stream output live to the console
					process.OutputDataReceived += (sender, e) =>
					{
						if (!string.IsNullOrEmpty(e.Data) && e.Data.StartsWith("Encoding:"))
						{
							Console.WriteLine(e.Data);
							string percent = e.Data.Split("(")[0];
							percent = percent.Split(",")[1];
							percent = percent.Replace("%", "").Trim();

							if (double.TryParse(percent, out double percentDbl))
								CurrentProgressPercent = percentDbl;

							Console.WriteLine($"Percent : {percent}");

							InvokeAsync(() =>
							{
								CurrentProgressPercent = percentDbl;
								StateHasChanged();
							});
						}
					};

					process.ErrorDataReceived += (sender, e) =>
					{
						if (!string.IsNullOrEmpty(e.Data))
						{
							// HandBrake writes its progress ticks (e.g., % done) here
							Console.WriteLine($"[HandBrake LOG] {e.Data}");
						}
					};

					// 2. Start the process
					process.Start();

					// 3. CRITICAL: Begin reading the streams asynchronously
					process.BeginOutputReadLine();
					process.BeginErrorReadLine();

					// 4. Await the exit of the application safely
					await process.WaitForExitAsync();

					Console.WriteLine("Finished Transcoding");
				}
			}
		}





	}

}
