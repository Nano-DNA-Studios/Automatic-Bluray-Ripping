@rendermode InteractiveServer
@inject SubtitleQueue SubQueue

<div style="margin-left: 20px; border-left: 2px solid #ccc; padding: 10px;" class="@(Stream.IsSelected ? "subtitle-card selected" : "subtitle-card unselected")" @onclick="(e) => { Stream.IsSelected = !Stream.IsSelected; }" @onclick:stopPropagation="true">
	<h5>(@Stream.ID) - @Stream.Language (@Stream.Format)</h5>

	<div style="display: flex; flex-direction: row; justify-content: flex-start; align-items:center; gap:10px;" @onclick:stopPropagation="true">
		<h5 style="margin:0px;">Name:</h5>
		<input @bind="@Stream.Name" style="width:100%; margin:0px;" />
	</div>

	<div style="display: flex; flex-direction: row; justify-content: flex-start; align-items:center; gap:10px;">
		<input type="checkbox"
			   class="form-check-input"
			   id="burn-in"
			   @bind="@Stream.BurnIn"
			   style="width: 30px; height:30px; margin:0px;" />

		<h5 style="margin:0px;">Burn In</h5>
	</div>

	<div style="display: flex; flex-direction: row; justify-content: flex-start; align-items:center; gap:10px; ">
		<input type="checkbox"
			   class="form-check-input"
			   id="default"
			   @bind="@Stream.Default"
			   style="width: 30px; height:30px; margin:0px" />

		<h5 style="margin:0px;">Default</h5>
	</div>

	<div style="display: flex; flex-direction: row; justify-content: flex-start; align-items:center; gap:10px;" @onclick:stopPropagation="true">
		<button style="margin-top: 10px; flex-grow:1;" @onclick="PreviewSubtitles">
			Preview
		</button>
	</div>
</div>

@code {
	[Parameter]
	public SubtitleStreamItem Stream { get; set; } = new SubtitleStreamItem();

	[Parameter]
	public VideoMetadata Metadata { get; set; } = new VideoMetadata();

	private void PreviewSubtitles()
	{
		Console.WriteLine("Showing Preview");
		SubQueue.ShowPreview(Metadata, Stream);
	}
}
